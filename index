<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>도란도란 - 시니어 프로그램 플랫폼</title>
  <meta name="description" content="자녀의 웹사이트 탐색과 시니어의 AI 전화 한 통으로, 어르신의 취미가 소속감과 소득이 되는 로컬 시니어 프로그램 플랫폼">
  <link href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      theme: { extend: {
        colors: { brand: { navy:'#1A2B4C', purple:'#B57CC4', blue:'#3A9DD5', pink:'#C379BD', dark:'#22242A', surface:'#F9F8F4' } },
        fontFamily: { serif:['"Nanum Myeongjo"','serif'], sans:['"Noto Sans KR"','sans-serif'] }
      }}
    }
  </script>
  <style>
    *{box-sizing:border-box;}
    body{font-family:'Noto Sans KR',sans-serif;overflow-x:hidden;background:#F9F8F4;margin:0;}
    .font-serif{font-family:'Nanum Myeongjo',serif;}
    .material-symbols-outlined{font-variation-settings:'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24;display:inline-block;vertical-align:middle;line-height:1;}
    html{scroll-behavior:smooth;}

    /* ── Hero: 원래 등축 도시 일러스트 (일본어 완벽 제거 버전) ── */
    .hero-bg{
      background-image: url('bg_clean.png');
      background-size: cover;
      background-position: center top;
      background-repeat: no-repeat;
      position: relative;
    }


    .glass-nav{background:rgba(255,255,255,0.92);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);}

    /* ── Animations ── */
    @keyframes fadeInLeft{from{opacity:0;transform:translateX(-24px)}to{opacity:1;transform:translateX(0)}}
    @keyframes fadeInRight{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:translateX(0)}}
    @keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    @keyframes wave{0%,100%{height:5px}50%{height:16px}}
    @keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.2)}}
    .anim-left{animation:fadeInLeft .8s ease-out both;}
    .anim-right{animation:fadeInRight .8s ease-out both;}

    /* ── Nav ── */
    .nav-btn{
      font-size:14px;font-weight:500;color:#1A2B4C;cursor:pointer;
      display:flex;align-items:center;gap:4px;transition:color .2s;
      background:none;border:none;padding:0;font-family:'Noto Sans KR',sans-serif;
    }
    .nav-btn:hover{color:#B57CC4;}
    .nav-arrow{width:14px;height:14px;flex-shrink:0;}

    /* ── Action cards ── */
    .action-card{
      display:flex;align-items:center;gap:14px;border-radius:16px;padding:14px 18px;
      color:white;cursor:pointer;
      transition:transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s;
      box-shadow:0 6px 24px rgba(0,0,0,.18);font-weight:700;font-size:14px;
      width:100%;border:none;text-align:left;
    }
    .action-card:hover{transform:translateX(-8px);box-shadow:0 10px 32px rgba(0,0,0,.22);}
    .action-icon{width:34px;height:34px;border-radius:8px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;}

    .info-badge{
      background:rgba(255,255,255,.97);border:2px solid #B57CC4;border-radius:28px;
      padding:12px 18px;text-align:center;width:220px;position:relative;
      box-shadow:0 4px 20px rgba(181,124,196,.2);
    }

    /* ── Program cards ── */
    .program-card{background:white;border-radius:18px;box-shadow:0 4px 20px rgba(26,43,76,.08);overflow:hidden;cursor:pointer;transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s;}
    .program-card:hover{transform:translateY(-5px);box-shadow:0 12px 40px rgba(26,43,76,.14);}
    .section-label{font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#B57CC4;}

    /* ── Phone frame ── */
    .phone-frame{width:300px;background:#fff;border-radius:36px;box-shadow:0 0 0 2px #1A2B4C,0 24px 60px rgba(0,0,0,.22);overflow:hidden;flex-shrink:0;}
    .phone-notch{width:100px;height:22px;background:#111;border-radius:0 0 14px 14px;margin:0 auto;}
    .dial-key{width:60px;height:60px;border-radius:50%;border:1.5px solid rgba(26,43,76,.15);background:white;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:all .15s;box-shadow:0 2px 6px rgba(0,0,0,.06);user-select:none;}
    .dial-key:hover{background:#e9edff;transform:scale(1.07);}
    .dial-key:active{transform:scale(.92);background:#d8e2ff;}
    .wave-bar{width:3px;background:#1A2B4C;border-radius:2px;animation:wave 1.2s ease-in-out infinite;}

    /* ── Signup modal ── */
    .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);z-index:1000;align-items:center;justify-content:center;}
    .modal-overlay.open{display:flex;}
    .modal-box{background:white;border-radius:24px;padding:40px 36px;max-width:480px;width:90%;box-shadow:0 24px 80px rgba(0,0,0,.2);position:relative;animation:fadeInUp .35s ease-out both;}
    .signup-card{border:2px solid transparent;border-radius:16px;padding:22px;cursor:pointer;transition:all .25s;background:#F9F8F4;display:flex;align-items:flex-start;gap:16px;text-decoration:none;color:inherit;}
    .signup-card:hover{border-color:#B57CC4;background:#fdf4ff;transform:scale(1.01);}
  </style>
</head>
<body class="text-brand-navy">

<!-- ══════════════════════════════════════
     HEADER
══════════════════════════════════════ -->
<header class="fixed top-0 left-0 w-full z-50 glass-nav border-b border-gray-100" style="height:72px;">
  <div style="max-width:1280px;margin:0 auto;padding:0 32px;height:100%;display:flex;align-items:center;justify-content:space-between;">

<!-- ══════════════════════════════════════
     JAVASCRIPT
══════════════════════════════════════ -->
<script>
  function goToSection(id) {
    const el = document.getElementById(id);
    if (el) {
      const offset = 72;
      const bodyRect = document.body.getBoundingClientRect().top;
      const elementRect = el.getBoundingClientRect().top;
      const elementPosition = elementRect - bodyRect;
      const offsetPosition = elementPosition - offset;
      window.scrollTo({
        top: offsetPosition,
        behavior: 'smooth'
      });
    }
  }

  function openSignup() {
    document.getElementById('signup-modal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSignup() {
    document.getElementById('signup-modal').classList.remove('open');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSignup(); });

  let isSpeakerOn = false, isMuted = false;
  function handleDial(key) {
    const sub = document.getElementById('phone-subtitle');
    if (key === '1') sub.innerHTML = '<span style="color:#C379BD;font-weight:700;">광화문 수제청</span>으로 연결 중...';
    else if (key === '2') sub.innerHTML = '<span style="color:#3A9DD5;font-weight:700;">성수동 목공예</span>로 연결 중...';
    else if (key === '0') sub.innerHTML = '상담원을 연결 중입니다...';
    else sub.innerHTML = `<span style="font-weight:700;">${key}</span>번을 누르셨습니다.`;
    if (navigator.vibrate) navigator.vibrate(40);
  }
  function toggleSpeaker() {
    isSpeakerOn = !isSpeakerOn;
    const ic = document.getElementById('speaker-icon'), ci = document.getElementById('speaker-circle');
    if (isSpeakerOn) { ic.textContent = 'volume_off'; ci.style.background = '#1A2B4C'; ic.style.color = 'white'; }
    else { ic.textContent = 'volume_up'; ci.style.background = 'white'; ic.style.color = '#1A2B4C'; }
  }
  function toggleMute() {
    isMuted = !isMuted;
    const ic = document.getElementById('mute-icon'), ci = document.getElementById('mute-circle');
    if (isMuted) { ic.textContent = 'mic_off'; ci.style.background = '#ba1a1a'; ci.style.borderColor = '#ba1a1a'; ic.style.color = 'white'; }
    else { ic.textContent = 'mic'; ci.style.background = 'white'; ci.style.borderColor = 'rgba(26,43,76,.18)'; ic.style.color = '#1A2B4C'; }
  }

  const subtitles = [
    '"광화문 수제청은 <span style="color:#ba1a1a;font-weight:700;">1</span>번,<br>성수동 목공예는 <span style="color:#ba1a1a;font-weight:700;">2</span>번을 눌러주세요."',
    '"예약 일정 확인은 <span style="color:#ba1a1a;font-weight:700;">3</span>번을 눌러주세요."',
    '"상담원 연결은 <span style="color:#ba1a1a;font-weight:700;">0</span>번을 눌러주세요."'
  ];
  let subIdx = 0;
  setInterval(() => {
    const bar = document.getElementById('phone-progress-bar');
    if (!bar) return;
    bar.style.width = '0%';
    setTimeout(() => {
      bar.style.width = '100%';
      subIdx = (subIdx + 1) % subtitles.length;
      document.getElementById('phone-subtitle').innerHTML = subtitles[subIdx];
    }, 60);
  }, 5000);
</script>


    <div style="display:flex;align-items:center;gap:10px;cursor:pointer;" onclick="window.scrollTo({top:0,behavior:'smooth'})">
      <div style="width:40px;height:40px;background:#B57CC4;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:18px;" class="font-serif">도</div>
      <span class="font-serif" style="font-size:22px;font-weight:800;color:#1A2B4C;">도란도란</span>
    </div>
    <!-- Nav — 모든 항목에 아래 화살표 추가 -->
    <nav style="display:flex;align-items:center;gap:26px;">
      <button class="nav-btn" onclick="goToSection('programs')">프로그램 찾기 <svg class="nav-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></button>
      <button class="nav-btn" onclick="goToSection('service-guide')">프로그램 가이드 <svg class="nav-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></button>
      <button class="nav-btn" onclick="goToSection('why')">우리 동네 이야기 <svg class="nav-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></button>
      <button class="nav-btn" onclick="goToSection('news-section')">뉴스 <svg class="nav-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></button>
    </nav>
    <!-- Right -->
    <div style="display:flex;align-items:center;gap:16px;">
      <a href="mailto:hello@dorandoran.kr" style="display:flex;align-items:center;gap:6px;font-size:13px;color:#1A2B4C;text-decoration:none;" class="nav-btn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
        문의하기
      </a>
      <a href="#" style="color:#C379BD;display:flex;transition:color .2s;" onmouseover="this.style.color='#a06ab0'" onmouseout="this.style.color='#C379BD'">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.584.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </a>
      <button onclick="openSignup()" style="background:#B57CC4;color:white;border:none;padding:10px 22px;border-radius:999px;font-size:13px;font-weight:700;cursor:pointer;transition:all .25s;" onmouseover="this.style.background='#a06ab0'" onmouseout="this.style.background='#B57CC4'">참여 신청</button>
    </div>
  </div>
</header>


<!-- ══════════════════════════════════════

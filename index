</div>


<!-- ══════════════════════════════════════
     HERO SECTION — 깨끗한 AI 생성 배경
══════════════════════════════════════ -->
<main class="hero-bg" style="min-height:100vh;padding-top:72px;display:flex;align-items:center;overflow:hidden;position:relative;">
  <!-- Blue dot marker on the orange building in the center-right of illustration -->
  <div style="position:absolute; left:62.5%; top:36.5%; width:10px; height:10px; background:#0052cc; border-radius:50%; border:2px solid white; z-index:2; box-shadow:0 0 10px rgba(0,82,204,0.6); pointer-events:none; animation: pulse-dot 2s infinite;"></div>

  <div style="position:relative;z-index:5;max-width:1280px;margin:0 auto;padding:40px 32px 80px;width:100%;display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center;">

    <!-- LEFT: Hero text (글자 뒤에 더 투명한 흰색 박스 적용) -->
    <div class="anim-left" style="position:relative; max-width:650px; background:rgba(255, 255, 255, 0.5); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); padding: 36px 40px; border-radius: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid rgba(255, 255, 255, 0.5);">
      <h1 class="font-serif" style="font-size:clamp(32px,4.5vw,50px);font-weight:800;color:#1A2B4C;line-height:1.45;margin:0 0 16px;letter-spacing:-0.02em;">
        활력이 소득이 되는<br>
        특별한 연결.
      </h1>
      <p style="font-size:15px;font-weight:500;color:#333333;line-height:1.8;margin:0;">
        시니어 프로그램 플랫폼 <span class="font-serif" style="font-weight:800;color:#B57CC4;">도란도란</span>
      </p>
    </div>

    <!-- RIGHT: Action cards -->
    <div class="anim-right" style="display:flex;flex-direction:column;align-items:flex-end;gap:12px;margin-top:20px;">
      <!-- Speech bubble badge pointing down to the cards -->
      <div id="info-badge-container" style="margin-bottom:8px; position:relative; align-self:flex-end; animation: fadeInUp .5s ease-out both;">
        <div style="background:#fff; border: 1.5px solid #C379BD; border-radius: 999px; padding: 10px 18px; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(181,124,196,0.15); position: relative; z-index: 10;">
          <span style="color:#C379BD; font-weight:700; font-size:13px; white-space:nowrap;">어르신 취미 프로그램 참여 안내</span>
          <button onclick="document.getElementById('info-badge-container').style.display='none'" style="background:none; border:none; cursor:pointer; color:#999; font-size:14px; padding: 0 0 2px 2px; line-height:1; display:flex; align-items:center;">✕</button>
        </div>
        <div style="position:absolute; bottom:-5px; right:40px; width:10px; height:10px; background:#fff; border-right:1.5px solid #C379BD; border-bottom:1.5px solid #C379BD; transform:rotate(45deg); z-index:5;"></div>
      </div>
      
      <!-- 성수동 목공예 -->
      <button class="action-card" style="background:#3A9DD5;max-width:260px;" onclick="goToSection('programs')">
        <div class="action-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
        </div>
        <span>성수동 목공예 프로그램 상세</span>
      </button>
      
      <!-- 광화문 수제청 -->
      <button class="action-card" style="background:#C379BD;max-width:260px;" onclick="goToSection('programs')">
        <div class="action-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
        <span>광화문 수제청 클래스 상세</span>
      </button>
      
      <!-- 실시간 상담원 -->
      <button class="action-card" style="background:#22242A;max-width:260px;" onclick="openSignup()">
        <div class="action-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
        </div>
        <span>실시간 상담원 연결</span>
      </button>
    </div>
  </div>
</main>


<!-- ══════════════════════════════════════
     PROGRAMS
══════════════════════════════════════ -->
<section id="programs" style="background:#F9F8F4;padding:100px 32px;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:60px;">
      <span class="section-label">프로그램 안내</span>
      <h2 class="font-serif" style="font-size:42px;font-weight:800;color:#1A2B4C;margin:14px 0 16px;">함께하는 프로그램</h2>
      <p style="color:#666;font-size:17px;line-height:1.8;max-width:460px;margin:0 auto;">어르신의 손끝에서 탄생하는 작품이<br>소득이 되고, 이웃이 되는 특별한 경험</p>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:28px;">
      <!-- 성수동 목공예 -->
      <div class="program-card" onclick="goToSection('service-guide')">
        <div style="height:220px;position:relative;overflow:hidden;">
          <img src="woodwork.png" alt="성수동 목공예" style="width:100%;height:100%;object-fit:cover;" onerror="this.parentElement.style.background='linear-gradient(135deg,#3A9DD5,#1A2B4C)';this.style.display='none'">
          <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(26,43,76,.6) 0%,transparent 60%);"></div>
          <div style="position:absolute;bottom:14px;left:16px;background:rgba(58,157,213,.9);color:white;padding:4px 12px;border-radius:999px;font-size:12px;font-weight:700;">📍 성수동</div>
        </div>
        <div style="padding:26px;">
          <h3 class="font-serif" style="font-size:22px;font-weight:800;color:#1A2B4C;margin:0 0 10px;">목공예 프로그램</h3>
          <p style="color:#666;font-size:14px;line-height:1.7;margin:0 0 18px;">손으로 뚝딱거리기 좋아하시는 어르신을 위한 목공예 클래스. 완성품을 팔아 용돈도 버세요.</p>
